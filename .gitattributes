# 文本文件使用LF行尾，跨平台兼容
*.txt text eol=lf
*.cpp text eol=lf
*.h text eol=lf
*.hpp text eol=lf
*.hxx text eol=lf
*.cc text eol=lf
*.cxx text eol=lf
*.c text eol=lf
*.cmake text eol=lf
CMakeLists.txt text eol=lf
.gitignore text eol=lf
.gitattributes text eol=lf
*.json text eol=lf
*.md text eol=lf
*.sh text eol=lf

# 二进制文件不进行行尾转换
*.exe binary
*.dll binary
*.lib binary
*.obj binary
*.o binary
*.a binary
*.so binary
*.dylib binary
*.jpg binary
*.jpeg binary
*.png binary
*.gif binary
*.ico binary
*.zip binary
*.7z binary
*.tar binary
*.gz binary

# 其他可能的文件类型
*.pdf binary
*.docx binary
*.xlsx binary